# Root Environment Variables for Deployment

# Production environment indicator
NODE_ENV=production

# Database URI (Use a managed MongoDB Atlas URI or EC2 local MongoDB URI)
MONGODB_URI=mongodb://localhost:27017/canteen_db

# Web Server Port (80 for standard HTTP is common if you have auth, or run on 5000 and proxy)
PORT=5000

# Security secrets
JWT_SECRET=super-secure-production-secret-here

# React Frontend API Base (In production when served by the same node server, this can be relative)
# For Vite, if the backend serves the frontend, API calls can just go to /api
VITE_API_URL=/api
